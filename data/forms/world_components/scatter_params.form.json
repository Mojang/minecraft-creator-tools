      "choices": [
        {
          "id": "xyz",
          "title": "Xyz"
        },
        {
          "id": "xzy",
          "title": "Xzy"
        },
        {
          "id": "yxz",
          "title": "Yxz"
        },
        {
          "id": "yzx",
          "title": "Yzx"
        },
        {
          "id": "zxy",
          "title": "Zxy"
        },
        {
          "id": "zyx",
          "title": "Zyx"
        }
      ],
      "defaultValue": "xzy"
    },
    {
      "id": "iterations",
