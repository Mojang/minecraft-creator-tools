{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "id": "Spawn HeightFilter",
  "title": "Height Filter",
  "description": "Restricts entity spawning to specific Y-coordinate ranges. Useful for creating depth-based mob distribution like slimes in swamps (below Y=40), or limiting surface mobs from spawning underground.",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "spawns at height "
          },
          {
            "type": "value",
            "field": "min"
          },
          {
            "type": "literal",
            "text": " to "
          },
          {
            "type": "value",
            "field": "max"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "max",
      "title": "Max",
      "dataType": "int",
      "defaultValue": 128
    },
    {
      "id": "min",
      "title": "Min",
      "dataType": "int",
      "defaultValue": 24
    }
  ]
}