      "title": "Format Version",
      "isRequired": true
    },
    {
      "dataType": "keyedObjectCollection",
      "id": "animation_controllers",
      "title": "Animation Controllers",
      "isRequired": true,
      "subForm": {
        "fields": [
          {
            "dataType": "keyedObjectCollection",
            "id": "states",
            "title": "States",
            "isRequired": true,
            "subForm": {
              "fields": [
                {
                  "dataType": "keyedObjectCollection",
