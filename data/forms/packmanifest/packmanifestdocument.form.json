{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "id": "3.0.0.PackManifestDocument",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "defines a complete pack manifest with header, modules, dependencies, and settings"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "capabilities",
      "title": "Capabilities",
      "dataType": "stringArray"
    },
    {
      "id": "dependencies",
      "title": "Dependencies",
      "dataType": "stringArray"
    },
    {
      "id": "format_version",
      "title": "Format Version",
      "dataType": "int",
      "validity": [
        {
          "comparison": "<=",
          "value": 255
        }
      ],
      "isRequired": true
    },
    {
      "id": "has_education_metadata",
      "title": "Has Education Metadata",
      "dataType": "boolean"
    },
    {
      "id": "header",
      "title": "Header",
      "dataType": "object",
      "subFormId": "packmanifest/header",
      "isRequired": true
    },
    {
      "id": "metadata",
      "title": "Metadata",
      "dataType": "object",
      "subFormId": "packmanifest/metadata"
    },
    {
      "id": "modules",
      "title": "Modules",
      "dataType": "objectArray",
      "minLength": 1,
      "subFormId": "packmanifest/module",
      "isRequired": true
    },
    {
      "id": "settings",
      "title": "Settings",
      "dataType": "stringArray",
      "minLength": 1,
      "maxLength": 50
    },
    {
      "id": "subpacks",
      "title": "Subpacks",
      "dataType": "objectArray",
      "subFormId": "packmanifest/subpack"
    }
  ],
  "description": "The root structure of a manifest.json file that defines an add-on pack. Every behavior pack and resource pack requires a manifest with a unique UUID, version info, and module declarations. This is the entry point Minecraft uses to identify and load your content.",
  "title": "Packmanifest PackManifestDocument"
}
