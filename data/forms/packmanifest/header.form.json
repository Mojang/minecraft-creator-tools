          "id": "pack_optimization_version",
          "dataType": "string"
        }
      ]
    },
    {
      "id": "pack_scope",
      "title": "Pack Scope",
      "dataType": "string"
    },
    {
      "id": "platform_locked",
      "title": "Platform Locked",
      "dataType": "boolean"
    },
