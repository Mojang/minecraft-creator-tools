        {
          "comparison": "pattern",
          "value": "^([1-9]+)\\.([0-9]+)\\.([0-9]+)$"
        }
      ],
      "subForm": {
        "id": "version",
        "title": "Version",
        "fields": [
          {
            "id": "buildMeta",
            "title": "BuildMeta",
            "dataType": "string",
            "defaultValue": ""
          },
          {
            "id": "major",
            "title": "Major",
            "dataType": "int",
            "defaultValue": 0
          },
          {
            "id": "minor",
            "title": "Minor",
            "dataType": "int",
            "defaultValue": 0
          },
          {
            "id": "patch",
            "title": "Patch",
            "dataType": "int",
            "defaultValue": 0
          },
          {
            "id": "preRelease",
            "title": "PreRelease",
            "dataType": "string",
            "defaultValue": ""
          }
        ]
      },
      "alternates": [
        {
          "id": "version",
          "dataType": "string"
        }
      ],
      "isRequired": true
    }
  ],
  "description": "The header section of manifest.json containing the pack's identity: its name shown in the UI, description, unique UUID, and version. The min_engine_version field specifies the minimum Minecraft version required to load the pack.",
  "title": "Packmanifest Header"
}
