  "samples": {
    "example": [
      {
        "path": "Carve nether caves normally",
        "content": {
          "format_version": "1.13.0",
          "minecraft:nether_cave_carver_feature": {
            "description": {
              "identifier": "example:nether_cave_carver_feature"
            },
