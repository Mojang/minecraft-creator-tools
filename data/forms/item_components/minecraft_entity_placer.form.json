{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "visibility": [
          {
            "field": "entity",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "spawns "
          },
          {
            "type": "value",
            "field": "entity"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "dispense_on",
      "description": "List of block descriptors of the blocks that this item can be dispensed on. If left empty, all blocks will be allowed.",
      "dataType": "objectArray",
      "defaultValue": [],
      "subForm": {
        "id": "dispense_on",
        "title": "Dispense On",
        "fields": [
          {
            "id": "name",
            "title": "Name",
            "dataType": "string",
            "defaultValue": ""
          },
          {
            "id": "states",
            "title": "States",
            "dataType": "int",
            "defaultValue": {},
            "alternates": [
              {
                "id": "states",
                "dataType": "string"
              },
              {
                "id": "states",
                "dataType": "boolean"
              }
            ]
          },
          {
            "id": "tags",
            "title": "Tags",
            "dataType": "string",
            "defaultValue": ""
          }
        ]
      },
      "alternates": [
        {
          "id": "dispense_on",
          "dataType": "string"
        },
        {
          "id": "dispense_on",
          "dataType": "object"
        }
      ],
      "title": "dispense_on"
    },
    {
      "id": "entity",
      "title": "Entity",
      "description": "The entity to be placed in the world.",
      "dataType": "object",
      "defaultValue": "",
      "validity": [
        {
          "comparison": "pattern",
          "value": "^(?:\\w+(?:\\.\\w+)*:(?=\\w))?(?:\\w+(?:\\.\\w+)*)(?:<((?:\\w+(?:\\.\\w+)*:(?=\\w))?\\w+(?:\\.\\w+)*)*>)?$"
        }
      ],
      "samples": {
        "/samples/custom_items/behavior_packs/custom_item/items/my_sword_turtle.json": [
          {
            "path": "/minecraft:item/components/minecraft:entity_placer/",
            "content": "minecraft:turtle"
          }
        ]
      }
    },
    {
      "id": "use_on",
      "description": "List of block descriptors of the blocks that this item can be used on. If left empty, all blocks will be allowed.",
      "dataType": "objectArray",
      "defaultValue": [],
      "subForm": {
        "id": "use_on",
        "title": "Use On",
        "fields": [
          {
            "id": "name",
            "title": "Name",
            "dataType": "string",
            "defaultValue": ""
          },
          {
            "id": "states",
            "title": "States",
            "dataType": "int",
            "defaultValue": {},
            "alternates": [
              {
                "id": "states",
                "dataType": "string"
              },
              {
                "id": "states",
                "dataType": "boolean"
              }
            ]
          },
          {
            "id": "tags",
            "title": "Tags",
            "dataType": "string",
            "defaultValue": ""
          }
        ]
      },
      "alternates": [
        {
          "id": "use_on",
          "dataType": "string"
        },
        {
          "id": "use_on",
          "dataType": "object"
        }
      ],
      "samples": {
        "/samples/custom_items/behavior_packs/custom_item/items/my_sword_turtle.json": [
          {
            "path": "/minecraft:item/components/minecraft:entity_placer/",
            "content": [
              "minecraft:sand"
            ]
          }
        ]
      },
      "title": "use_on"
    }
  ],
  "description": "Allows an item to place entities into the world. Additionally, in version 1.19.80 and above, the component allows the item to set the spawn type of a monster spawner.",
  "samples": {
    "sample": [
      {
        "path": "sample",
        "content": {
          "entity": "minecraft:spider",
          "dispense_on": [
            "minecraft:web"
          ],
          "use_on": [
            "minecraft:web"
          ]
        }
      }
    ],
    "/samples/custom_items/behavior_packs/custom_item/items/my_sword_turtle.json": [
      {
        "path": "/minecraft:item/components/minecraft:entity_placer/",
        "content": {
          "entity": "minecraft:turtle",
          "use_on": [
            "minecraft:sand"
          ]
        }
      }
    ]
  },
  "title": "Item Components Entity Placer",
  "id": "minecraft:entity_placer"
}
