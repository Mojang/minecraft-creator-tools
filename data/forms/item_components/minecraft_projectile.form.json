        "content": {
          "minimum_critical_power": 1.25,
          "projectile_entity": "minecraft:snowball"
        }
      }
    ],
    "/samples/custom_items/behavior_packs/custom_item/items/my_sword_shoot.json": [
      {
        "path": "/minecraft:item/components/minecraft:projectile/",
        "content": {
          "minimum_critical_power": 1.25,
          "projectile_entity": "minecraft:snowball"
        }
      }
    ]
  },
