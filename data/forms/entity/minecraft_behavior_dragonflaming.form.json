    {
      "id": "smoke_color",
      "title": "Smoke Color",
      "dataType": "string",
      "defaultValue": "#DC00EF"
    },
    {
      "id": "smoke_radius",
      "title": "Smoke Radius",
      "dataType": "float",
      "defaultValue": 5
    },
    {
      "id": "smoke_time",
      "title": "Smoke Time",
      "dataType": "float",
      "defaultValue": 10
    }
