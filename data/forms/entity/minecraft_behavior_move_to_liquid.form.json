{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "moves toward liquids (deprecated)"
          }
        ]
      }
    ]
  },
  "id": "minecraft:behavior.move_to_liquid",
  "description": "Allows the mob to move into a liquid when on land.",
  "fields": [
    {
      "id": "control_flags",
      "title": "Control Flags",
      "dataType": "stringArray",
      "defaultValue": [],
      "choices": [
        {
          "id": "jump",
          "title": "Jump"
        },
        {
          "id": "look",
          "title": "Look"
        },
        {
          "id": "move",
          "title": "Move"
        }
      ]
    },
    {
      "id": "goal_radius",
      "title": "Goal Radius",
      "description": "Distance in blocks within the mob considers it has reached the goal. This is the \"wiggle room\" to stop the AI from bouncing back and forth trying to reach a specific spot.",
      "dataType": "float",
      "defaultValue": 0.5,
      "validity": [
        {
          "comparison": ">",
          "value": 0
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/strider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:strider_pathing_behaviors/minecraft:behavior.move_to_liquid/",
            "content": 0.9
          }
        ]
      }
    },
    {
      "id": "material_type",
      "title": "Liquid Material Type",
      "description": "The material type of the liquid block to find. Valid values are \"Any\", \"Water\", and \"Lava\".",
      "dataType": "string",
      "choices": [
        {
          "id": "Any",
          "title": "Any"
        },
        {
          "id": "Lava",
          "title": "Lava"
        },
        {
          "id": "Water",
          "title": "Water"
        }
      ],
      "defaultValue": "any",
      "samples": {
        "/vanilla/behavior_pack/entities/strider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:strider_pathing_behaviors/minecraft:behavior.move_to_liquid/",
            "content": "Lava"
          }
        ]
      }
    },
    {
      "id": "priority",
      "title": "Priority",
      "dataType": "int",
      "defaultValue": 0,
      "samples": {
        "/vanilla/behavior_pack/entities/strider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:strider_pathing_behaviors/minecraft:behavior.move_to_liquid/",
            "content": 7
          }
        ]
      },
      "description": "As priority approaches 0, the priority is increased. The higher the priority, the sooner this behavior will be executed as a goal."
    },
    {
      "id": "search_count",
      "title": "Search Count",
      "description": "The number of randomly selected blocks each tick that the mob will check within its search range and height for a valid block to move to. A value of 0 will have the mob check every block within range in one tick.",
      "dataType": "int",
      "defaultValue": 10,
      "samples": {
        "/vanilla/behavior_pack/entities/strider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:strider_pathing_behaviors/minecraft:behavior.move_to_liquid/",
            "content": 30
          }
        ]
      }
    },
    {
      "id": "search_height",
      "title": "Search Height",
      "description": "Height in blocks the mob will look for the liquid block to move towards",
      "dataType": "int",
      "defaultValue": 1,
      "validity": [
        {
          "comparison": ">",
          "value": 0
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/strider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:strider_pathing_behaviors/minecraft:behavior.move_to_liquid/",
            "content": 10
          }
        ]
      }
    },
    {
      "id": "search_range",
      "title": "Search Range",
      "description": "The distance in blocks it will look for the liquid block to move towards",
      "dataType": "int",
      "defaultValue": 0,
      "validity": [
        {
          "comparison": ">",
          "value": 0
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/strider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:strider_pathing_behaviors/minecraft:behavior.move_to_liquid/",
            "content": 16
          }
        ]
      }
    },
    {
      "id": "speed_multiplier",
      "title": "Speed Multiplier",
      "description": "Movement speed multiplier of the mob when using this goal.",
      "dataType": "float",
      "defaultValue": 1
    }
  ],
  "title": "Entity Move To Liquid Behavior",
  "samples": {
    "/vanilla/behavior_pack/entities/strider.json": [
