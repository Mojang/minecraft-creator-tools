              {
                "cause": "lava",
                "damage_per_tick": 4,
                "filters": {
                  "operator": "==",
                  "test": "in_lava",
                  "subject": "self",
                  "value": true
                }
              }
            ]
          }
        ]
      }
    }
  ],
