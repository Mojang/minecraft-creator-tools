{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "jumps to specific blocks"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "control_flags",
      "title": "Control Flags",
      "dataType": "stringArray",
      "defaultValue": [],
      "choices": [
        {
          "id": "jump",
          "title": "Jump"
        },
        {
          "id": "look",
          "title": "Look"
        },
        {
          "id": "move",
          "title": "Move"
        }
      ]
    },
    {
      "id": "cooldown_range",
      "title": "Cooldown Range",
      "description": "Minimum and maximum cooldown time-range (positive, in seconds) between each attempted jump.",
      "dataType": "object",
      "defaultValue": {
        "max": 20,
        "min": 10
      },
      "technicalDescription": "Check that the limits imposed on the range (minimum, maximum and maximum distance between values) are respected",
      "subFormId": "item_components/floatrange",
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": [
              5,
              7
            ]
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": [
              30,
              60
            ]
          }
        ]
      }
    },
    {
      "id": "forbidden_blocks",
      "title": "Forbidden Blocks",
      "description": "Blocks that the mob can't jump to.",
      "dataType": "string",
      "defaultValue": [],
      "alternates": [
        {
          "id": "forbidden_blocks",
          "dataType": "keyedStringCollection"
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": [
              "minecraft:water"
            ]
          }
        ]
      }
    },
    {
      "id": "max_velocity",
      "title": "Max Velocity",
      "description": "The maximum velocity with which the mob can jump.",
      "dataType": "float",
      "defaultValue": 1.5,
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 1
          }
        ]
      }
    },
    {
      "id": "minimum_distance",
      "title": "Minimum Distance",
      "description": "The minimum distance (in blocks) from the mob to a block, in order to consider jumping to it.",
      "dataType": "int",
      "defaultValue": 2,
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 1
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 1
          }
        ]
      }
    },
    {
      "id": "minimum_path_length",
      "title": "Minimum Path Length",
      "description": "The minimum length (in blocks) of the mobs path to a block, in order to consider jumping to it.",
      "dataType": "int",
      "defaultValue": 5,
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 2
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 8
          }
        ]
      }
    },
    {
      "id": "preferred_blocks",
      "title": "Preferred Blocks",
      "description": "Blocks that the mob prefers jumping to.",
      "dataType": "string",
      "defaultValue": [],
      "alternates": [
        {
          "id": "preferred_blocks",
          "dataType": "keyedStringCollection"
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": [
              "minecraft:waterlily",
              "minecraft:big_dripleaf"
            ]
          }
        ]
      }
    },
    {
      "id": "preferred_blocks_chance",
      "title": "Preferred Blocks Chance",
      "description": "Chance (between 0.0 and 1.0) that the mob will jump to a preferred block, if in range. Only matters if preferred blocks are defined.",
      "dataType": "float",
      "defaultValue": 1,
      "validity": [
        {
          "comparison": "<=",
          "value": 1
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 0.5
          }
        ]
      }
    },
    {
      "id": "priority",
      "title": "Priority",
      "dataType": "int",
      "defaultValue": 0,
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 10
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 8
          }
        ]
      },
      "description": "As priority approaches 0, the priority is increased. The higher the priority, the sooner this behavior will be executed as a goal."
    },
    {
      "id": "scale_factor",
      "title": "Scale Factor",
      "description": "The scalefactor of the bounding box of the mob while it is jumping.",
      "dataType": "float",
      "defaultValue": 0.699999988079071,
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 0.6
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 0.6
          }
        ]
      }
    },
    {
      "id": "search_height",
      "title": "Search Height",
      "description": "The height (in blocks, in range [1, 15]) of the search box, centered around the mob.",
      "dataType": "int",
      "defaultValue": 10,
      "validity": [
        {
          "comparison": ">=",
          "value": 1
        },
        {
          "comparison": "<=",
          "value": 15
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 4
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 10
          }
        ]
      }
    },
    {
      "id": "search_width",
      "title": "Search Width",
      "description": "The width (in blocks, in range [1, 15]) of the search box, centered around the mob.",
      "dataType": "int",
      "defaultValue": 8,
      "validity": [
        {
          "comparison": ">=",
          "value": 1
        },
        {
          "comparison": "<=",
          "value": 15
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/frog.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 8
          }
        ],
        "/vanilla/behavior_pack/entities/goat.json": [
          {
            "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
            "content": 10
          }
        ]
      }
    }
  ],
  "description": "Allows an entity to jump to another random block.",
  "title": "Entity Jump To Block Behavior",
  "samples": {
    "/vanilla/behavior_pack/entities/frog.json": [
      {
        "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
        "content": {
          "cooldown_range": [
            5,
            7
          ],
          "priority": 10,
          "max_velocity": 1,
          "forbidden_blocks": [
            "minecraft:water"
          ],
          "minimum_distance": 1,
          "minimum_path_length": 2,
          "preferred_blocks": [
            "minecraft:waterlily",
            "minecraft:big_dripleaf"
          ],
          "preferred_blocks_chance": 0.5,
          "scale_factor": 0.6,
          "search_height": 4,
          "search_width": 8
        }
      }
    ],
    "/vanilla/behavior_pack/entities/goat.json": [
      {
        "path": "/minecraft:entity/components/minecraft:behavior.jump_to_block/",
        "content": {
          "priority": 8,
          "search_width": 10,
          "search_height": 10,
          "minimum_path_length": 8,
          "minimum_distance": 1,
          "scale_factor": 0.6,
          "cooldown_range": [
            30,
            60
          ]
        }
      }
    ]
  },
  "id": "minecraft:behavior.jump_to_block"
}
