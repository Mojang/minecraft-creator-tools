{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "visibility": [
          {
            "field": "spawn_entity",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "periodically spawns "
          },
          {
            "type": "value",
            "field": "spawn_entity",
            "humanify": "minecraft"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "spawn_entity",
            "comparison": "undefined"
          },
          {
            "field": "spawn_item",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "periodically spawns "
          },
          {
            "type": "value",
            "field": "spawn_item",
            "humanify": "minecraft"
          },
          {
            "type": "literal",
            "text": " items"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "spawn_entity",
            "comparison": "undefined"
          },
          {
            "field": "spawn_item",
            "comparison": "undefined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "periodically spawns entities or items"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "min_wait_time",
            "comparison": "defined"
          },
          {
            "field": "max_wait_time",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "waits between "
          },
          {
            "type": "value",
            "field": "min_wait_time"
          },
          {
            "type": "literal",
            "text": " and "
          },
          {
            "type": "value",
            "field": "max_wait_time"
          },
          {
            "type": "literal",
            "text": " seconds between spawns"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "num_to_spawn",
            "comparison": ">",
            "value": 1
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "spawns "
          },
          {
            "type": "value",
            "field": "num_to_spawn"
          },
          {
            "type": "literal",
            "text": " at a time"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "single_use",
            "comparison": "=",
            "value": true
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "only spawns once (single use)"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "should_leash",
            "comparison": "=",
            "value": true
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "leashes spawned entities to itself"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "spawn_event",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "triggers "
          },
          {
            "type": "value",
            "field": "spawn_event",
            "humanify": "minecraft"
          },
          {
            "type": "literal",
            "text": " on spawned entities"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "entities",
      "title": "Entities",
      "description": "List of entity spawn definitions. Can be a single object or an array of objects.",
      "dataType": "objectArray",
      "subForm": {
        "id": "spawn_entity_entry",
        "fields": [
          {
            "id": "filters",
            "title": "Filters",
            "description": "If present, the specified entity will only spawn if the filter evaluates to true.",
            "dataType": "minecraftFilter",
            "samples": {
              "/vanilla/behavior_pack/entities/chicken.json": [
                {
                  "path": "filters",
                  "content": [
                    {
                      "test": "rider_count",
                      "subject": "self",
                      "operator": "==",
                      "value": 0
                    },
                    {
                      "test": "enum_property",
                      "subject": "self",
                      "domain": "minecraft:climate_variant",
                      "value": "temperate"
                    }
                  ]
                }
              ]
            }
          },
          {
            "id": "min_wait_time",
            "title": "Min wait time",
            "dataType": "number",
            "samples": {
              "/vanilla/behavior_pack/entities/chicken.json": [
                {
                  "path": "min_wait_time",
                  "content": 300
                }
              ]
            }
          },
          {
            "id": "max_wait_time",
            "title": "Max wait time",
            "dataType": "number",
            "samples": {
              "/vanilla/behavior_pack/entities/chicken.json": [
                {
                  "path": "max_wait_time",
                  "content": 600
                }
              ]
            }
          },
          {
            "id": "spawn_sound",
            "title": "Spawn sound",
            "dataType": "string",
            "samples": {
              "/vanilla/behavior_pack/entities/chicken.json": [
                {
                  "path": "spawn_sound",
                  "content": "plop"
                }
              ]
            }
          },
          {
            "id": "spawn_item",
            "title": "Spawn item",
            "dataType": "string",
            "samples": {
              "/vanilla/behavior_pack/entities/chicken.json": [
                {
                  "path": "spawn_item",
                  "content": "egg"
                }
              ]
            }
          }
        ],
        "title": "Entities"
      },
      "alternates": [
        {
          "id": "entities",
          "dataType": "object"
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/chicken.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:chicken_adult/minecraft:spawn_entity/",
            "content": [
              {
                "min_wait_time": 300,
                "max_wait_time": 600,
                "spawn_sound": "plop",
                "spawn_item": "egg",
                "filters": [
                  {
                    "test": "rider_count",
                    "subject": "self",
                    "operator": "==",
                    "value": 0
                  },
                  {
                    "test": "enum_property",
                    "subject": "self",
                    "domain": "minecraft:climate_variant",
                    "value": "temperate"
                  }
                ]
              },
              {
                "min_wait_time": 300,
                "max_wait_time": 600,
                "spawn_sound": "plop",
                "spawn_item": "brown_egg",
                "filters": [
                  {
                    "test": "rider_count",
                    "subject": "self",
                    "operator": "==",
                    "value": 0
                  },
                  {
                    "test": "enum_property",
                    "subject": "self",
                    "domain": "minecraft:climate_variant",
                    "value": "warm"
                  }
                ]
              },
              {
                "min_wait_time": 300,
                "max_wait_time": 600,
                "spawn_sound": "plop",
                "spawn_item": "blue_egg",
                "filters": [
                  {
                    "test": "rider_count",
                    "subject": "self",
                    "operator": "==",
                    "value": 0
                  },
                  {
                    "test": "enum_property",
                    "subject": "self",
                    "domain": "minecraft:climate_variant",
                    "value": "cold"
                  }
                ]
              }
            ]
          }
        ],
        "/vanilla/behavior_pack/entities/drowned.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:drowned_rider/minecraft:spawn_entity/",
            "content": {
              "max_wait_time": 0,
              "min_wait_time": 0,
              "num_to_spawn": 1,
              "single_use": true,
              "spawn_entity": "minecraft:zombie_nautilus",
              "spawn_event": "minecraft:entity_spawned"
            }
          }
        ],
        "/vanilla/behavior_pack/entities/sniffer.json": [
          {
            "path": "/minecraft:entity/component_groups/sniffer_pregnant/minecraft:spawn_entity/",
            "content": {
              "min_wait_time": 0,
              "max_wait_time": 0,
              "spawn_sound": "plop",
              "spawn_item": "sniffer_egg",
              "spawn_item_event": {
                "event": "on_egg_spawned",
                "target": "self"
              },
              "single_use": true
            }
          }
        ]
      }
    },
    {
      "id": "filters",
      "title": "Filters",
      "description": "If present, the specified entity will only spawn if the filter evaluates to true.",
      "dataType": "minecraftFilter"
    },
    {
      "id": "max_wait_time",
      "title": "Max Wait Time",
      "description": "Maximum amount of time to randomly wait in seconds before another entity is spawned.",
      "defaultValue": 600,
      "dataType": "int"
    },
    {
      "id": "min_wait_time",
      "title": "Min Wait Time",
      "description": "Minimum amount of time to randomly wait in seconds before another entity is spawned.",
      "defaultValue": 300,
      "dataType": "int"
    },
    {
      "id": "num_to_spawn",
      "title": "Num To Spawn",
      "description": "The number of entities of this type to spawn each time that this triggers.",
      "defaultValue": 1,
      "dataType": "int"
    },
    {
      "id": "should_leash",
      "title": "Should Leash",
      "description": "If true, this the spawned entity will be leashed to the parent.",
      "defaultValue": false,
      "dataType": "boolean"
    },
    {
      "id": "single_use",
      "title": "Single Use",
      "description": "If true, this component will only ever spawn the specified entity once.",
      "defaultValue": false,
      "dataType": "boolean"
    },
    {
      "id": "spawn_entity",
      "title": "Spawn Entity",
      "description": "Identifier of the entity to spawn, leave empty to spawn the item defined by \"spawn_item\" instead.",
      "dataType": "string"
    },
    {
      "id": "spawn_event",
      "title": "Spawn Event",
      "description": "Event to call on the spawned entity when it spawns.",
      "defaultValue": "minecraft:entity_born",
      "dataType": "minecraftEventTrigger"
    },
    {
      "id": "spawn_item",
      "title": "Spawn Item",
      "description": "Item identifier of the item to spawn.",
      "defaultValue": "egg",
      "dataType": "string"
    },
    {
      "id": "spawn_item_event",
      "title": "Spawn Item Event",
      "description": "Event to call on this entity when the item is spawned.",
      "dataType": "minecraftEventTrigger"
    },
    {
      "id": "spawn_method",
      "title": "Spawn Method",
      "description": "Method to use to spawn the entity.",
      "defaultValue": "born",
      "dataType": "string"
    },
    {
      "id": "spawn_sound",
      "title": "Spawn Sound",
      "description": "Identifier of the sound effect to play when the entity is spawned.",
      "defaultValue": "plop",
      "dataType": "string"
    }
  ],
  "description": "Adds a timer after which this entity will spawn another entity or item (similar to vanilla's chicken's egg-laying behavior).",
  "title": "Spawn Entity",
