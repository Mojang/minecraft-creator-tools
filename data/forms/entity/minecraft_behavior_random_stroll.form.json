          },
          {
            "type": "value",
            "field": "y_dist"
          },
          {
            "type": "literal",
            "text": " blocks vertically"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "speed_multiplier",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "moves at "
          },
          {
            "type": "switch",
            "cases": [
              {
                "conditions": [
                  {
                    "field": "speed_multiplier",
                    "comparison": ">",
                    "value": 1
                  }
                ],
                "tokens": [
                  {
                    "type": "literal",
                    "text": "fast"
                  }
                ]
              },
              {
                "conditions": [
                  {
                    "field": "speed_multiplier",
                    "comparison": "<",
                    "value": 0.6
                  }
                ],
                "tokens": [
                  {
                    "type": "literal",
                    "text": "slow"
                  }
                ]
              }
            ],
            "default": [
              {
                "type": "literal",
                "text": "normal"
              }
            ]
          },
          {
            "type": "literal",
            "text": " speed ("
          },
          {
            "type": "value",
            "field": "speed_multiplier"
          },
          {
            "type": "literal",
            "text": "x)"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "interval",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "has a 1/"
          },
          {
            "type": "value",
            "field": "interval"
          },
          {
            "type": "literal",
            "text": " chance per tick to start strolling"
          }
        ]
      }
    ]
  },
