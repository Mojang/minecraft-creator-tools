{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "teleports to its owner"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "control_flags",
      "title": "Control Flags",
      "dataType": "stringArray",
      "defaultValue": [],
      "choices": [
        {
          "id": "jump",
          "title": "Jump"
        },
        {
          "id": "look",
          "title": "Look"
        },
        {
          "id": "move",
          "title": "Move"
        }
      ]
    },
    {
      "id": "cooldown",
      "title": "Cooldown",
      "description": "The time in seconds that must pass for the entity to be able to try to teleport again.",
      "dataType": "float",
      "defaultValue": 1
    },
    {
      "id": "filters",
      "description": "Conditions to be satisfied for the entity to teleport to its owner.",
      "dataType": "object",
      "defaultValue": {
        "AND": null,
        "NOT": null,
        "OR": null,
        "all": null,
        "all_of": null,
        "any": null,
        "any_of": null,
        "none_of": null
      },
      "subForm": {
        "id": "filters",
        "title": "Filters",
        "fields": [
          {
            "id": "domain",
            "title": "Domain",
            "description": "The domain the test should be performed in.",
            "dataType": "object"
          },
          {
            "id": "operator",
            "title": "Operator",
            "description": "The comparison to apply with 'value'.",
            "dataType": "object"
          },
          {
            "id": "subject",
            "title": "Subject",
            "description": "The subject of this filter test.",
            "dataType": "object"
          },
          {
            "id": "test",
            "title": "Test",
            "description": "The name of the test to apply.",
            "dataType": "string",
            "isRequired": true
          },
          {
            "id": "value",
            "title": "Value",
            "description": "The value being compared with the test.",
            "dataType": "object"
          }
        ]
      },
      "alternates": [
        {
          "id": "filters",
          "dataType": "object"
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/parrot.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:parrot_tame/minecraft:behavior.teleport_to_owner/",
            "content": {
              "all_of": [
                {
                  "test": "owner_distance",
                  "operator": ">",
                  "value": 12
                },
                {
                  "test": "is_panicking"
                }
              ]
            }
          }
        ]
      },
      "title": "Filters"
    },
    {
      "id": "priority",
      "title": "Priority",
      "dataType": "int",
      "defaultValue": 0,
      "description": "As priority approaches 0, the priority is increased. The higher the priority, the sooner this behavior will be executed as a goal."
    }
  ],
  "description": "Allows an entity to teleport to its owner.",
  "title": "Entity Teleport To Owner Behavior",
  "samples": {
    "/vanilla/behavior_pack/entities/parrot.json": [
      {
        "path": "/minecraft:entity/component_groups/minecraft:parrot_tame/minecraft:behavior.teleport_to_owner/",
        "content": {
          "filters": {
            "all_of": [
              {
                "test": "owner_distance",
                "operator": ">",
                "value": 12
              },
              {
                "test": "is_panicking"
              }
            ]
          },
          "priority": 0
        }
      }
    ]
  },
  "id": "minecraft:behavior.teleport_to_owner"
}
