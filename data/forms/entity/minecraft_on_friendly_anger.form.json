{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "triggers an event when nearby entities of the same type become angry"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "event",
      "title": "Event",
      "description": "The event to run when the conditions for this trigger are met.",
      "dataType": "string",
      "samples": {
        "/vanilla/behavior_pack/entities/polar_bear.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:adult_wild/minecraft:on_friendly_anger/",
            "content": "minecraft:on_anger"
          }
        ],
        "/vanilla/behavior_pack/entities/trader_llama.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:llama_wandering_trader/minecraft:on_friendly_anger/",
            "content": "minecraft:defend_wandering_trader"
          }
        ]
      }
    },
    {
      "id": "filters",
      "title": "Filters",
      "description": "The list of conditions for this trigger to execute.",
      "dataType": "minecraftFilter"
    },
    {
      "id": "target",
      "title": "Target",
      "description": "The target of the event.",
      "defaultValue": "self",
      "dataType": "string",
      "samples": {
        "/vanilla/behavior_pack/entities/polar_bear.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:adult_wild/minecraft:on_friendly_anger/",
            "content": "self"
          }
        ],
        "/vanilla/behavior_pack/entities/trader_llama.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:llama_wandering_trader/minecraft:on_friendly_anger/",
            "content": "self"
          }
        ]
      }
    }
  ],
  "description": "Adds a trigger that will run when a nearby entity of the same type as this entity becomes Angry.",
  "title": "On Friendly Anger",
  "samples": {
    "/vanilla/behavior_pack/entities/polar_bear.json": [
      {
        "path": "/minecraft:entity/component_groups/minecraft:adult_wild/minecraft:on_friendly_anger/",
        "content": {
          "event": "minecraft:on_anger",
          "target": "self"
        }
      }
    ],
    "/vanilla/behavior_pack/entities/trader_llama.json": [
      {
        "path": "/minecraft:entity/component_groups/minecraft:llama_wandering_trader/minecraft:on_friendly_anger/",
        "content": {
          "event": "minecraft:defend_wandering_trader",
          "target": "self"
        }
      }
    ]
  },
  "id": "minecraft:on_friendly_anger"
}