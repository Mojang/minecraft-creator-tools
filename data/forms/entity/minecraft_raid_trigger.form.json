            "samples": {
              "/vanilla/behavior_pack/entities/player.json": [
                {
                  "path": "triggered_event",
                  "content": {
                    "event": "minecraft:remove_raid_trigger",
                    "target": "self"
                  }
                }
              ]
            }
          }
        ]
      },
      "samples": {
        "/vanilla/behavior_pack/entities/player.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:raid_trigger/",
            "content": {
              "triggered_event": {
                "event": "minecraft:remove_raid_trigger",
                "target": "self"
              }
            }
          }
        ]
      }
    }
  ],
  "description": "Attempts to trigger a raid at the entity's location.",
  "title": "Raid Trigger",
  "samples": {
    "/vanilla/behavior_pack/entities/player.json": [
      {
        "path": "/minecraft:entity/component_groups/minecraft:raid_trigger/",
        "content": {
