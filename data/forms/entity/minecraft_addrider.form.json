{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "adds a rider to this entity"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "entity_type",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "spawns with a "
          },
          {
            "type": "value",
            "field": "entity_type",
            "humanify": "minecraft"
          },
          {
            "type": "literal",
            "text": " rider"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "spawn_event",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "triggering event on spawn"
          }
        ]
      }
    ]
  },
  "title": "Add Rider",
  "requires": [
    {
      "id": "minecraft:rideable",
      "type": "entity_component"
    }
  ],
  "description": "Adds a rider to the entity.",
  "fields": [
    {
      "id": "entity_type",
      "title": "Entity type to ride",
      "description": "Type of entity to acquire as a rider",
      "dataType": "stringLookup",
      "lookupId": "entityType"
    },
    {
      "id": "spawn_event",
      "description": "Trigger event when a rider is acquired",
      "dataType": "minecraftEventReference",
      "lookupId": "entityTypeEvents",
      "title": "Spawn Event"
    },
    {
      "id": "riders",
      "title": "Riders",
      "description": "List of riders to be added to the entity. Can only spawn as many riders as \"minecraft:rideable\" has \"seat_count\".",
      "dataType": "objectArray",
      "subFormId": "entity/rider_data",
      "mergeSubForm": true,
      "samples": {
        "/vanilla/behavior_pack/entities/cave_spider.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:spider_bogged_jockey/minecraft:addrider/",
            "content": [
              {
                "entity_type": "minecraft:bogged"
              }
            ]
          },
          {
            "path": "/minecraft:entity/component_groups/minecraft:spider_wither_jockey/minecraft:addrider/",
            "content": [
              {
                "entity_type": "minecraft:wither_skeleton"
              }
            ]
          }
        ]
      },
      "defaultValue": []
    }
  ],
