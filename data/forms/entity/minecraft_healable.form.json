{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "can be healed by feeding it items"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "force_use",
            "comparison": "=",
            "value": true
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "accepts healing items even at full health"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "filters",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "has conditional healing requirements"
          }
        ]
      }
    ]
  },
  "description": "How entities heal",
  "fields": [
    {
      "id": "force_use",
      "title": "Whether an item can be used even if the entity is at full health",
      "dataType": "boolean",
      "samples": {
        "/vanilla/behavior_pack/entities/parrot.json": [
          {
            "path": "/minecraft:entity/components/minecraft:healable/",
            "content": true
          }
        ]
      },
      "defaultValue": false,
      "description": "Determines if item can be used regardless of entity being at full health."
    },
    {
      "id": "filters",
      "title": "Additional filters when healing happens",
      "dataType": "minecraftFilter",
      "samples": {
        "/vanilla/behavior_pack/entities/parrot.json": [
          {
            "path": "/minecraft:entity/components/minecraft:healable/",
            "content": {
              "operator": "!=",
              "test": "is_riding",
              "value": true
            }
          }
        ]
      },
      "description": "The filter group that defines the conditions for using this item to heal the entity."
    },
    {
      "id": "items",
      "title": "Items",
      "description": "The array of items that can be used to heal this entity.",
      "dataType": "objectArray",
      "subForm": {
        "id": "",
        "description": "The array of items that can be used to heal this entity.",
        "fields": [
          {
            "id": "heal_amount",
            "title": "Heal Amount",
            "description": "The amount of health this entity gains when fed this item.",
            "defaultValue": 1,
            "dataType": "int"
          },
          {
            "id": "item",
            "title": "Item",
            "description": "Item identifier that can be used to heal this entity.",
            "dataType": "string"
          },
          {
            "id": "effects",
            "title": "Effects",
            "dataType": "objectArray",
            "subForm": {
              "id": "effects",
              "title": "Effects",
              "fields": [
                {
                  "id": "amplifier",
                  "title": "Amplifier",
                  "dataType": "number",
                  "samples": {
                    "/vanilla/behavior_pack/entities/parrot.json": [
                      {
                        "path": "amplifier",
                        "content": 0
                      }
                    ]
                  }
                },
                {
                  "id": "chance",
                  "title": "Chance",
                  "dataType": "number",
                  "samples": {
                    "/vanilla/behavior_pack/entities/parrot.json": [
                      {
                        "path": "chance",
                        "content": 1
                      }
                    ]
                  }
                },
                {
                  "id": "duration",
                  "title": "Duration",
                  "dataType": "number",
                  "samples": {
                    "/vanilla/behavior_pack/entities/parrot.json": [
                      {
                        "path": "duration",
                        "content": 1000
                      }
                    ]
                  }
                },
                {
                  "id": "name",
                  "title": "Name",
                  "dataType": "string",
                  "samples": {
                    "/vanilla/behavior_pack/entities/parrot.json": [
                      {
                        "path": "name",
                        "content": "fatal_poison"
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "samples": {
        "/vanilla/behavior_pack/entities/llama.json": [
          {
            "path": "/minecraft:entity/components/minecraft:healable/",
            "content": [
              {
                "item": "wheat",
                "heal_amount": 2
              },
              {
                "item": "hay_block",
                "heal_amount": 10
              }
            ]
          }
        ],
        "/vanilla/behavior_pack/entities/parrot.json": [
          {
            "path": "/minecraft:entity/components/minecraft:healable/",
            "content": [
              {
                "effects": [
                  {
                    "amplifier": 0,
                    "chance": 1,
                    "duration": 1000,
                    "name": "fatal_poison"
                  }
                ],
                "heal_amount": 0,
                "item": "cookie"
              }
            ]
          }
        ]
      }
    }
  ],
  "title": "Healable",
  "samples": {
    "/vanilla/behavior_pack/entities/llama.json": [
      {
        "path": "/minecraft:entity/components/minecraft:healable/",
        "content": {
          "items": [
            {
              "item": "wheat",
              "heal_amount": 2
            },
            {
              "item": "hay_block",
              "heal_amount": 10
            }
          ]
        }
      }
    ],
    "/vanilla/behavior_pack/entities/parrot.json": [
      {
        "path": "/minecraft:entity/components/minecraft:healable/",
        "content": {
          "filters": {
            "operator": "!=",
            "test": "is_riding",
            "value": true
          },
          "force_use": true,
          "items": [
            {
              "effects": [
                {
                  "amplifier": 0,
                  "chance": 1,
                  "duration": 1000,
                  "name": "fatal_poison"
                }
              ],
              "heal_amount": 0,
              "item": "cookie"
            }
          ]
        }
      }
    ],
    "/vanilla/behavior_pack/entities/sniffer.json": [
      {
        "path": "/minecraft:entity/components/minecraft:healable/",
        "content": {
          "items": [
            {
              "item": "torchflower_seeds",
              "heal_amount": 2
            }
          ]
        }
      }
    ],
    "/vanilla/behavior_pack/entities/trader_llama.json": [
      {
        "path": "/minecraft:entity/components/minecraft:healable/",
        "content": {
          "items": [
            {
              "item": "wheat",
              "heal_amount": 2
            },
            {
              "item": "hay_block",
              "heal_amount": 10
            }
          ]
        }
      }
    ]
  },
  "id": "minecraft:healable"
}