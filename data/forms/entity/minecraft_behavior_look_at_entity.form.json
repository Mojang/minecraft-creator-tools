      "defaultValue": 360,
      "validity": [
        {
          "comparison": "<=",
          "value": 360
        }
      ],
      "samples": {
        "/vanilla/behavior_pack/entities/ravager.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:hostile/minecraft:behavior.look_at_entity/",
            "content": 45
          }
        ]
      }
    },
    {
      "id": "angle_of_view_vertical",
