{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "allows baby entities to follow their parent"
          }
        ]
      },
      {
        "visibility": [
          {
            "field": "speed_multiplier",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "follows at "
          },
          {
            "type": "switch",
            "cases": [
              {
                "conditions": [
                  {
                    "field": "speed_multiplier",
                    "comparison": ">=",
                    "value": 2
                  }
                ],
                "tokens": [
                  {
                    "type": "literal",
                    "text": "very fast"
                  }
                ]
              },
              {
                "conditions": [
                  {
                    "field": "speed_multiplier",
                    "comparison": ">",
                    "value": 1
                  }
                ],
                "tokens": [
                  {
                    "type": "literal",
                    "text": "fast"
                  }
                ]
              },
              {
                "conditions": [
                  {
                    "field": "speed_multiplier",
                    "comparison": "<",
                    "value": 1
                  }
                ],
                "tokens": [
                  {
                    "type": "literal",
                    "text": "slow"
                  }
                ]
              }
            ],
            "default": [
              {
                "type": "literal",
                "text": "normal"
              }
            ]
          },
          {
            "type": "literal",
            "text": " speed ("
          },
          {
            "type": "value",
            "field": "speed_multiplier"
          },
          {
            "type": "literal",
            "text": "x)"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "control_flags",
      "title": "Control Flags",
      "dataType": "stringArray",
      "defaultValue": [],
      "choices": [
        {
          "id": "jump",
          "title": "Jump"
        },
        {
          "id": "look",
          "title": "Look"
        },
        {
          "id": "move",
          "title": "Move"
        }
      ]
    },
    {
      "id": "priority",
      "title": "Priority",
      "dataType": "int",
      "defaultValue": 0,
      "samples": {
        "/vanilla/behavior_pack/entities/chicken.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:chicken_baby/minecraft:behavior.follow_parent/",
            "content": 5
          }
        ],
        "/vanilla/behavior_pack/entities/dolphin.json": [
          {
            "path": "/minecraft:entity/component_groups/dolphin_baby/minecraft:behavior.follow_parent/",
            "content": 4
