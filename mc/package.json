{
  "name": "mctools",
  "version": "0.1.0",
  "productName": "Minecraft Creator Tools",
  "description": "Minecraft Creator Tools",
  "private": true,
  "devDependencies": {
    "@minecraft/core-build-tasks": "5.5.0",
    "eslint-plugin-minecraft-linting": "1.2.1",
    "source-map": "0.7.4",
    "ts-node": "10.9.1",
    "typescript": "5.0.2"
  },
  "scripts": {
    "lint": "just-scripts lint",
    "build": "just-scripts build-ingame",
    "clean": "just-scripts clean",
    "local-deploy": "just-scripts local-deploy",
    "local-deploy-editor": "just-scripts local-deploy-editor",
    "package": "just-scripts package-ingame",
    "package-editor": "just-scripts create-editor-mcaddon-file",
    "enablemcloopback": "CheckNetIsolation.exe LoopbackExempt -a -p=S-1-15-2-1958404141-86561845-1752920682-3514627264-368642714-62675701-733520436",
    "enablemcpreviewloopback": "CheckNetIsolation.exe LoopbackExempt -a -p=S-1-15-2-424268864-5579737-879501358-346833251-474568803-887069379-4040235476"
  },
  "dependencies": {
    "@minecraft/math": "1.1.0",
    "@minecraft/server": "2.3.0",
    "@minecraft/server-editor": "0.1.0-beta.1.21.130-preview.26",
    "@minecraft/server-gametest": "1.0.0-beta.1.21.130-preview.26",
    "@minecraft/server-ui": "2.0.0",
    "@minecraft/vanilla-data": "1.21.20",
    "ste-events": "3.0.11"
