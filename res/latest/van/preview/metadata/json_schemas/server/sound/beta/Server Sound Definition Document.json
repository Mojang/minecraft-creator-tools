{
  "$id": "4115391460",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "2103472662": {
      "description": "Server-authoritative duration metadata. When present, the server tracks the sound's lifetime.",
      "properties": {
        "mode": {
          "description": "How the duration drains: \"game_time\" decrements by tick, \"real_time\" decrements by wall-clock time.",
          "enum": [
            "game_time",
            "real_time"
          ],
          "title": "Server Sound Duration Mode",
          "type": "string"
        },
        "seconds": {
          "description": "Duration in seconds.",
          "type": "number"
        }
      },
      "required": [
        "mode",
        "seconds"
      ],
      "title": "Server Sound Duration Info",
      "type": "object"
    },
    "4283276213": {
      "description": "A single server-authoritative sound definition.",
      "properties": {
        "duration_info": {
          "$ref": "#/definitions/2103472662",
          "description": "Optional server-authoritative duration metadata."
        },
        "sound_event_name": {
          "description": "The namespaced sound event ID used to play this sound.",
          "pattern": "^\\S+$",
          "type": "string",
          "x-regex-flags": "ECMAScript,icase"
        }
      },
      "required": [
        "sound_event_name"
      ],
      "title": "Server Sound Definition",
      "type": "object"
    }
  },
  "items": {
    "$ref": "#/definitions/4283276213",
    "description": "A single server-authoritative sound definition."
  },
  "title": "Server Sound Definition Document",
  "type": "array",
  "x-format-version": "beta"
}