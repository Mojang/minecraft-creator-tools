{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.sulfur_cube": {
      "geometry": "query.is_baby ? Geometry.small : Geometry.default",
      "materials": [ { "*": "Material.default" } ],
      "textures": [ "query.is_baby ? Texture.small : (variable.has_absorbed_tnt ? Texture.tnt : Texture.default)" ],
      "part_visibility": [ { "*": "(!variable.has_absorbed_block && !query.is_invisible) || variable.has_absorbed_tnt" } ],
      "overlay_color": {
        "r": "variable.is_flashing ? 1.0 : this",
        "g": "variable.is_flashing ? 1.0 : this",
        "b": "variable.is_flashing ? 1.0 : this",
        "a": "variable.is_flashing ? 0.5 : this"
      }
    },
    "controller.render.sulfur_cube_outer": {
      "geometry": "query.is_baby ? Geometry.small : Geometry.default",
      "materials": [ { "*": "Material.outer" } ],
      "part_visibility": [ {"*":  "!query.is_invisible"} ],
      "textures": [ "query.is_baby ? Texture.outer_small : Texture.outer" ]
    }
  }
}
