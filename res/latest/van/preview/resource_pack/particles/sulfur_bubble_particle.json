{
	"format_version": "1.26.30",
	"particle_effect": {
		"description": {
			"identifier": "minecraft:sulfur_bubble_particle",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/bubble_white"
			}
		},
		"components": {
