{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2022",
		"outDir": "dist",
		"lib": [
			"es2022","WebWorker"
		],
		"types": [ "wicg-file-system-access"],
		"sourceMap": true,
		"rootDir": "src",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"strict": true,   /* enable all strict type-checking options */
		"noImplicitReturns": true, 
		"noFallthroughCasesInSwitch": true,
	//	"noUnusedParameters": true, 
	},
	"exclude": [
		"src/UX/**/*",
		"src/UXex/**/*",		
		"src/workers/**/*",
		"src/UX/world/**/*",
		"src/monaco/**/*",
		"src/babylon/**/*",
		"src/dataform/**/*",
		"src/local/**/*",
		"src/localserver/**/*",
		"src/test/**/*",
		"src/testweb/**/*",
		"src/testmobile/**/*",
		"src/testa11y/**/*",
		"src/test-ex/**/*",
		"src/test-extra/**/*",
		"src/test-longhaul/**/*",
		"src/testelectron/**/*",
		"src/testshared/**/*",
		"src/testserver/**/*",
		"src/testperf/**/*",
		"src/testreflow/**/*",
		"src/testviewers/**/*",
		"src/testvscweb/**/*",
		"src/cli/**/*",
		"src/mcp/**/*",
		"src/electron/**/*",
		"playwright*.config.ts",
		"playwright*.config.js",
		"out/**/*",		
		"public/**/*",
		"debugoutput/**/*",		
		"build/**/*",		
		"toolbuild/**/*",
		"archive/**/*",
		"scriptlibs/**/*",
		"test/results/**/*",
		"test/scenarios/**/*",
		"test-scripts/**/*",
		"src/index.tsx",
		"node_modules_archive/**/*",
		"node_modules/node-fetch/**/*",
		"src/vscwebindex.tsx",
		"src/vscode/extension.ts",
		"src/vscode/VscDedicatedServerManager.ts",
		"src/vscode/VscWebSocketServerManager.ts",
		"src/jsnwebindex.tsx",
		"src/index.ts",
		"src/storage/BrowserFile.ts",
		"src/storage/BrowserFolder.ts",
		"src/storage/BrowserStorage.ts",
	],
}
