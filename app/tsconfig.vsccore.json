{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2022",
		"outDir": "dist",
		"moduleResolution": "node",
		"lib": [
			"esnext","WebWorker"
		],
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"sourceMap": true,
		"rootDir": "src",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,		
		"strict": true, 
		"noImplicitReturns": true, 
		"noFallthroughCasesInSwitch": true,
	},
	"exclude": [
		"src/UX/**/*",
		"src/UXex/**/*",
		"src/workers/**/*",
		"node_modules_archive/**/*",
		"node_modules_overrides/**/*",
		"src/UX/world/**/*",
		"src/dataformux/**/*",
		"src/monaco/**/*",
		"src/babylon/**/*",
		"src/dataform/**/*",
		"src/local/**/*",
		"src/cli/**/*",
		"src/mcp/**/*",
		"src/test/**/*",
		"src/test-ex/**/*",
		"src/test-extra/**/*",
		"src/test-longhaul/**/*",
		"src/testweb/**/*",
		"src/testmobile/**/*",
		"src/testa11y/**/*",
		"src/testelectron/**/*",
		"src/testshared/**/*",
		"src/testperf/**/*",
		"src/testreflow/**/*",
		"src/testviewers/**/*",
		"src/testvscweb/**/*",
		"playwright*.config.ts",
		"playwright*.config.js",
		"out/**/*",		
		"public/**/*",		
		"debugoutput/**/*",		
		"build/**/*",		
		"toolbuild/**/*",
		"archive/**/*",
		"scriptlibs/**/*",
		"test/results/**/*",
		"test/scenarios/**/*",
		"test-scripts/**/*",
		"src/index.tsx",
		"src/vscode/webextension.ts",
		"node_modules/node-fetch/**/*",
		"src/vscwebindex.tsx",
		"src/jsnwebindex.tsx",
		"src/index.ts",
		"src/storage/BrowserFile.ts",
		"src/storage/BrowserFolder.ts",
		"src/storage/BrowserStorage.ts",
		"src/analytics/**/*",
	],
}
