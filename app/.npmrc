# Pin dependency versions by default (no ^ or ~ prefix on npm install --save)
save-exact=true

# Security: skip all lifecycle scripts from dependencies by default.
# After `npm ci` or `npm install`, run `npm run rebuild-deps` to execute
# lifecycle scripts ONLY for the explicitly allowed packages listed below.
#
# Allowed packages that require lifecycle scripts:
#   electron           - downloads platform-specific Electron binary
#   esbuild            - downloads platform-specific native binary
#   @vscode/vsce-sign  - downloads VS Code extension signing binary
#   @playwright/browser-chromium - downloads Chromium for Playwright tests
#   keytar             - downloads/compiles native credential storage addon
#   electron-winstaller - selects correct 7z architecture for packaging
#
# Intentionally blocked (no functional impact):
#   babylonjs          - just prints a console.log recommendation
#   @fortawesome/*     - writes attribution files only
#   es5-ext            - telemetry/analytics
ignore-scripts=true
