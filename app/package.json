    "waveform-playlist": "4.3.3",
    "ws": "8.18.3",
    "zod": "3.25.36"
  },
  "optionalDependencies": {},
  "scripts": {
    "app": "concurrently -k \"npm run env:options -- BROWSER=none vite\"  \"electron .\"",
    "apphelp": "electron . --cmd help",
    "electronforge": "electron-forge start",
    "electronb": "electron .",
    "electrona": "wait-on http://127.0.0.1:3000 && electron .",
    "electron": "wait-on http://127.0.0.1:3000 && electron-forge start",
    "preparedevenv": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp preparedevenv",
    "preparetest": "npx playwright install && cd ../samplecontent/addon && npm ci && npx gulp package && cd ../world && npm ci && npx gulp package && cd ../../app",
    "preparemc": "cd ../mc && npm ci --legacy-peer-deps && npm run build && npm run package && cd ../app",
    "env:options": "cross-env NODE_OPTIONS=--max-old-space-size=16384",
    "web": "npm run env:options -- vite",
    "start": "npm run env:options -- vite",
    "webbuild": "npm run env:options -- CI=true vite build",
    "vscbuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp vscbuild",
    "vsccorebuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp vsccorebuild",
    "jsntest": "npm run jsnbuild && npm run lint && npm run test && npm run test-web-core",
    "jsnbuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp jsnbuild",
    "jsnfullbuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp jsnfullbuild",
    "jsminbuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp jsminbuild",
    "jsncorebuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp jsncorebuild",
    "jsnwebbuild": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx gulp jsnwebbuild",
    "pack": "cd toolbuild/jsn && npm pack --pack-destination ../../debugoutput/packages",
    "enablejsn": "node -e \"require('fs').chmodSync('toolbuild/jsn/cli/index.mjs', 0o755);\"",
    "process": "npm run-script enablejsn && npx ./toolbuild/jsn/ validate --force --warn-only -q --ot noreports -i ./public/res/latest/van/release/ -o ./public/data && npx ./toolbuild/jsn/ validate --force --warn-only -q --ot noreports -i ./public/res/latest/van/preview/ -o ./public/data && npx ./toolbuild/jsn/ validate --force --warn-only -q --ot noreports -i ./public/res/samples/microsoft/samples/ -o ./public/data && npx gulp copyjsnodedata",
    "processcontent": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn/ docsgenerateformjson --base-path ./public/ -i ./../../minecraft-creator-pr/content/forms/ -o ./public/data/forms/",
    "updatetests": "rm -r test/scenarios && cp -r test/results test/scenarios && npx playwright test BlockViewer.spec.ts --project=chromium --timeout=120000 --update-snapshots",
    "updatejsontypes": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn/ docsgeneratetypes --base-path ./public/ -i ./public/data/forms/ -o ./debugoutput/jsontypes/",
    "updatejsonschemas": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn/ docsgeneratejsonschema -i ./public/data/forms/ -o ./debugoutput/jsonschemas/",
    "updateformsource": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn/ docsupdateformsource --base-path ./public/ -o ./../../minecraft-creator-pr/content/",
    "processdocs": "npm run-script enablejsn && npm run-script updateformsource && npm run-script processcontent && cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn docsgeneratemarkdown --base-path ./public/ -i ./public/data/forms/ -o ./debugoutput/msdocs/",
    "processdocs-safe": "npm run-script enablejsn && npm run-script updateformsource && npm run-script processcontent && cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn docsgeneratemarkdown --base-path ./public/ -i ./public/data/forms/ -o ./debugoutput/msdocs/ -ref ./../../minecraft-creator-pr/creator/Reference/Content",
    "updatefromdocs": "npm run-script updateformsource && npm run-script processcontent && npm run-script updatejsontypes",
    "generate-schemas": "node scripts/generateJsonSchemas.js",
    "generateschemapackage": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npx ./toolbuild/jsn/ generateschemapackage -i ./public/data/forms/ -o ./debugoutput/schemapackage/",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache \"src/**/*.{js,jsx,ts,tsx}\" \"scripts/**/*.{js,ts}\" \"*.config.{js,mjs,cjs,ts}\" \"playwright*.{js,ts}\" \"gulpfile.js\" \"vite.config.js\" \"config-overrides.js\"",
    "lint:fix": "npm run lint -- --fix",
    "lint-deps": "node scripts/check-pinned-dependencies.js package.json jsnode/package.json libnode/package.json vscode/package.json ../mc/package.json ../samplecontent/addon/package.json ../samplecontent/world/package.json",
    "all": "npm install && npm run-script preparemc && npm run-script allbuild && npm run-script preparetest && npm run-script test && npm run-script test-web",
    "allbuild": "npm run-script preparedevenvandjsnbuild && npm run-script webvscappbuild",
    "preparedevenvandjsnbuild": "npm run-script preparedevenv && npm run-script jsnbuild && npm run-script process",
    "corebuild": "npm run-script jsnbuild && npm run-script webbuild",
    "webvscappbuild": "npm run-script webbuild && npm run-script vscbuild && npm run-script appbuildandsetup",
    "updateversionsandbuild": "npx gulp updateversions && npm run-script webbuild && npm run-script jsnbuild && npm run-script process && npm run-script vscbuild && npm run-script appbuildandsetup && npx gulp customizesite",
    "appbuild": "npm run-script webbuild && npm run-script jsncorebuild && npm run-script appcorebuild",
    "appdebugbuild": "npm run-script webbuild && npm run-script jsncorebuild && cross-env FORGE_DEBUG=1 electron-forge package",
    "appcorebuild": "electron-forge package",
    "appbuildandsetup": "npm run-script appbuild && electron-forge make --skip-package",
    "test": "ts-mocha --type-check -p tsconfig.test.json src/test/**/*.ts",
    "test-mcp": "ts-mocha --type-check -p tsconfig.test.json src/test/McpToolsTest.ts",
    "test-mcp-unit": "ts-mocha --type-check -p tsconfig.test.json src/test/McpToolsTest.ts",
    "test-mcp-integration": "ts-mocha --type-check -p tsconfig.test-extra.json src/test-extra/McpServerIntegrationTest.ts",
    "test-mcp-http": "ts-mocha --type-check -p tsconfig.test-extra.json src/test-extra/McpHttpIntegrationTest.ts",
    "test-cli": "ts-mocha --type-check -p tsconfig.test.json src/test/CommandLineTest.ts src/test/ProjectCommandLineTest.ts src/test/ServerCommandLineTest.ts src/test/ContentCommandLineTest.ts",
    "test-package": "ts-mocha --type-check -p tsconfig.test.json src/test/PackageValidationTest.ts",
    "test-core": "ts-mocha --type-check -p tsconfig.test.json src/test/CreatorToolsTest.ts",
    "test-ci": "ts-mocha --type-check -p tsconfig.test.json src/test/**/*.ts --reporter json > test/test-results.json",
    "test-extra": "ts-mocha --type-check -p tsconfig.test-extra.json src/test-extra/**/*.ts",
    "test-extra-update": "cross-env UPDATE_SNAPSHOTS=true ts-mocha --type-check -p tsconfig.test-extra.json src/test-extra/**/*.ts",
    "test-extra-github": "ts-mocha --type-check -p tsconfig.test-extra.json src/test-extra/GitHubDependentTests.ts",
    "test-longhaul": "ts-mocha --type-check -p tsconfig.test-longhaul.json src/test-longhaul/**/*.ts",
    "test-longhaul-update": "cross-env UPDATE_SNAPSHOTS=true ts-mocha --type-check -p tsconfig.test-longhaul.json src/test-longhaul/**/*.ts",
    "update-snapshots": "npx ts-node -P tsconfig.test-extra.json test-scripts/updateSnapshots.ts",
    "update-snapshots-blocks": "npx ts-node -P tsconfig.test-extra.json test-scripts/updateSnapshots.ts --type block",
    "update-snapshots-mobs": "npx ts-node -P tsconfig.test-extra.json test-scripts/updateSnapshots.ts --type mob",
    "update-snapshots-items": "npx ts-node -P tsconfig.test-extra.json test-scripts/updateSnapshots.ts --type item",
    "test-longhaul-blocks": "ts-mocha --type-check -p tsconfig.test-longhaul.json src/test-longhaul/VanillaModelSnapshotTests.ts --grep \"Block\"",
    "test-longhaul-mobs": "ts-mocha --type-check -p tsconfig.test-longhaul.json src/test-longhaul/VanillaModelSnapshotTests.ts --grep \"Mob\"",
    "test-longhaul-2d": "ts-mocha --type-check -p tsconfig.test-longhaul.json src/test-longhaul/Model2DProfileSnapshotTests.ts",
    "test-longhaul-2d-update": "cross-env UPDATE_SNAPSHOTS=true ts-mocha --type-check -p tsconfig.test-longhaul.json src/test-longhaul/Model2DProfileSnapshotTests.ts",
    "test-web": "playwright test",
    "test-web-core": "playwright test --config playwright-core.config.js",
    "test-web-core-headed": "playwright test --config playwright-core.config.js --headed",
    "test-web-core-debug": "playwright test --config playwright-core.config.js --debug --workers=1",
    "test-web-system": "playwright test --config playwright-system.config.js",
    "test-web-mctoolsdev": "playwright test --config playwright-mctoolsdev.config.js",
    "test-web-ui": "npx playwright test --ui",
    "test-web-headed": "npx playwright test --headed",
    "test-web-mctoolsdev-headed": "playwright test --config playwright-mctoolsdev.config.js --headed --workers=1",
    "test-web-debug": "npx playwright test --debug --workers=1",
    "test-web-vscode": "playwright test --config playwright.config.js --workers=1",
    "test-web-list": "npx playwright test --list",
    "test-viewers": "playwright test --config playwright-viewers.config.js",
    "test-viewers-headed": "playwright test --config playwright-viewers.config.js --headed",
    "test-viewers-debug": "playwright test --config playwright-viewers.config.js --debug --workers=1",
    "test-reflow": "playwright test --config playwright-reflow.config.js",
    "test-reflow-headed": "playwright test --config playwright-reflow.config.js --headed",
    "test-reflow-debug": "playwright test --config playwright-reflow.config.js --debug --workers=1",
    "test-mobile": "playwright test --config playwright-mobile.config.js",
    "test-mobile-headed": "playwright test --config playwright-mobile.config.js --headed",
    "test-mobile-debug": "playwright test --config playwright-mobile.config.js --debug --workers=1",
    "test-a11y": "playwright test --config playwright-accessibility.config.js",
    "test-a11y-headed": "playwright test --config playwright-accessibility.config.js --headed",
    "test-a11y-debug": "playwright test --config playwright-accessibility.config.js --debug --workers=1",
    "test-server-ui": "playwright test --config playwright-serverui.config.ts",
    "test-server-ui-headed": "playwright test --config playwright-serverui.config.ts --headed",
    "test-server-ui-debug": "playwright test --config playwright-serverui.config.ts --debug",
    "test-electron": "playwright test --config playwright-electron.config.ts",
    "test-electron-headed": "playwright test --config playwright-electron.config.ts --headed",
    "test-electron-debug": "playwright test --config playwright-electron.config.ts --debug",
    "test-electron-full": "npm run webbuild && npm run jsncorebuild && playwright test --config playwright-electron.config.ts",
    "test-electron-dev": "cross-env ELECTRON_FORCE_PROD= playwright test --config playwright-electron.config.ts",
    "test-electron-dev-headed": "cross-env ELECTRON_FORCE_PROD= playwright test --config playwright-electron.config.ts --headed",
    "test-vscweb": "playwright test --config playwright-vscweb.config.js",
    "test-vscweb-headed": "playwright test --config playwright-vscweb.config.js --headed",
    "test-vscweb-debug": "playwright test --config playwright-vscweb.config.js --debug",
    "test-production": "playwright test --config playwright-production.config.js",
    "test-production-full": "npm run webbuild && playwright test --config playwright-production.config.js",
    "test-production-headed": "playwright test --config playwright-production.config.js --headed",
    "test-production-debug": "playwright test --config playwright-production.config.js --debug",
    "serve-production": "npx serve build -s -l 3001",
    "test-validate-setup": "node utilityscripts/validate-playwright-setup.js",
    "docker-build": "cd toolbuild/jsn && npm pack && cd ../.. && docker build -f docker-dev/Dockerfile -t mct:latest .",
    "docker-run": "docker run -d --name mct-server -e MCTOOLS_I_ACCEPT_EULA_AT_MINECRAFTDOTNETSLASHEULA=true -p 6126:6126 -p 19132:19132/udp mct:latest",
    "docker-stop": "docker stop mct-server && docker rm mct-server",
    "docker-compose-up": "cd docker-dev && docker-compose up -d",
    "docker-compose-down": "cd docker-dev && docker-compose down",
    "eject": "react-scripts eject",
    "vscweb": "vscode-test-web --browserType=chromium --esm --quality=stable --port=3040 --extensionDevelopmentPath=./toolbuild/vsc/ ../samplecontent/simple/",
    "package-vsccore": "webpack --config webpack.vsccore.config.js --mode production --devtool hidden-source-map"
  },
  "bin": {
    "mct": "./toolbuild/jsn/cli/index.mjs"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "overrides": {
    "@minecraft/math": {
      "@minecraft/server": "$@minecraft/server"
    },
    "@minecraft/server-gametest": {
      "@minecraft/server": "$@minecraft/server"
    },
    "@minecraft/server-ui": {
      "@minecraft/server": "$@minecraft/server"
    }
  },
