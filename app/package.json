    "font-awesome": "4.7.0",
    "ink": "5.0.1",
    "ink-select-input": "6.2.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "inquirer": "9.3.8",
    "js-md5": "0.8.3",
    "json-schema": "0.4.0",
    "json-stable-stringify": "1.3.0",
    "jszip": "3.10.1",
    "leaflet": "1.7.1",
    "localforage": "1.9.0",
    "monaco-editor": "0.48.0",
    "node-abi": "4.12.0",
    "obscenity": "0.4.3",
    "open": "8.3.0",
    "pako": "2.0.4",
    "pngjs": "7.0.0",
    "react": "18.3.1",
    "react-blockly": "9.0.0",
    "react-dom": "18.3.1",
    "react-intl": "6.8.9",
    "react-markdown": "8.0.7",
    "react-qr-code": "2.0.15",
    "react-syntax-highlighter": "16.1.0",
    "react-window": "2.2.7",
    "remark-gfm": "3.0.1",
    "ste-events": "2.0.9",
    "tui-grid": "4.21.22",
    "utf-8-validate": "6.0.3",
    "uuid": "9.0.0",
    "vinyl": "3.0.1",
