  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mojang/minecraft-creator-tools.git"
  },
  "main": "toolbuild/jsn/electron/main.mjs",
  "homepage": "./",
  "icon": "build/logo512.png",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/noto-sans": "5.0.22",
