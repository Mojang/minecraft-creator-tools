{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "outDir": "toolbuild/testvsc",
    "lib": ["es2022"],
    "types": ["node", "mocha", "vscode"],
    "typeRoots": ["./node_modules/@types"],
    "sourceMap": true,
    "rootDir": "src/testvsc",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/testvsc/**/*"]
}
