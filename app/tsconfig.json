{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "vite/client",
      "wicg-file-system-access",
      "mocha"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipDefaultLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "debugoutput",
    "out",
    "build",
    "toolbuild",
    "public/**/*",
    "src/cli/**/*",
    "src/mcp/**/*",
    "src/test/**/*",
    "src/test-ex/**/*",
    "src/test-extra/**/*",
    "src/test-longhaul/**/*",
    "src/testweb/**/*",
    "src/testmobile/**/*",
    "src/testa11y/**/*",
    "src/testelectron/**/*",
    "playwright*.config.ts",
    "playwright*.config.js",
    "src/local/**/*"
  ]
}