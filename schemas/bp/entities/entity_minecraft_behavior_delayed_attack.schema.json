{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Entity Delayed Attack Behavior",
  "description": "Allows an entity to attack, while also delaying the damage-dealt until a specific time in the attack animation.",
  "properties": {
    "attack_duration": {
      "title": "Attack Duration",
      "description": "The entity's attack animation will play out over this duration (in seconds). Also controls attack cooldown.",
      "type": "number",
      "default": 0.75
    },
    "attack_once": {
      "title": "Attack Once",
      "description": "Allows the mob to perform this melee attack behavior only once during its lifetime.",
      "type": "boolean",
      "default": false
    },
    "attack_types": {
      "title": "Attack Types",
      "description": "Defines the entity types this entity will attack.",
      "type": "string",
      "default": ""
    },
    "can_spread_on_fire": {
      "title": "Can Spread On Fire",
      "description": "Allows the mob, if on fire and empty handed, to ignite its target upon a successful attack.",
      "type": "boolean",
      "default": false
    },
    "control_flags": {
      "title": "Control Flags",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "jump",
          "look",
          "move"
        ]
      }
    },
    "hit_delay_pct": {
      "title": "Hit Delay Pct",
      "description": "The percentage into the attack animation to apply the damage of the attack (1.0 = 100%).",
      "type": "number",
      "maximum": 1,
      "default": 0.5
    },
    "inner_boundary_time_increase": {
      "title": "Inner Boundary Time Increase",
      "description": "Time, in seconds, added to the attack path recalculation interval when the target is beyond \"path_inner_boundary\".",
      "type": "number",
      "default": 0.25
    },
    "max_path_time": {
      "title": "Max Path Time",
      "description": "Maximum base time, in seconds, before recalculating a new attack path to the target (before increases are applied).",
      "type": "number",
      "default": 0.550000011920929
    },
    "melee_fov": {
      "title": "Melee Fov",
      "description": "Field of view, in degrees, used by the hard-coded sensing component to detect a valid attack target.",
      "type": "number",
      "default": 90
    },
    "min_path_time": {
      "title": "Min Path Time",
      "description": "Minimum base time, in seconds, before recalculating a new attack path to the target (before increases are applied).",
      "type": "number",
      "default": 0.20000000298023224
    },
    "on_attack": {
      "title": "Attack",
      "description": "Defines the event to trigger when this entity successfully attacks.\n\nProperties:\n• event (string) = \n• filters ({ domain, operator, subject, ... }) = {\"AND\":null,\"NOT\":nu\n• target (string) = self",
      "$ref": "./entity_actordefinitiontrigger.schema.json",
      "defaultSnippets": [
        {
          "label": "Entity ActorDefinitionTrigger",
          "description": "Triggers an entity event when specified conditions are met. Events activate component groups that change entity behavior—transforming villagers into zombie villagers, switching mobs to aggressive mode, or triggering growth stages. Combine with filters to create conditional state machines that respond to gameplay.",
          "body": {
            "event": "",
            "filters": {
              "AND": null,
              "NOT": null,
              "OR": null,
              "all": null,
              "all_of": null,
              "any": null,
              "any_of": null,
              "none_of": null
            },
            "target": "self"
          }
        }
      ]
    },
    "on_kill": {
      "title": "Kill",
      "description": "Defines the event to trigger when this entity kills the target.\n\nProperties:\n• event (string) = \n• filters ({ domain, operator, subject, ... }) = {\"AND\":null,\"NOT\":nu\n• target (string) = self",
      "$ref": "./entity_actordefinitiontrigger.schema.json",
      "defaultSnippets": [
        {
          "label": "Entity ActorDefinitionTrigger",
          "description": "Triggers an entity event when specified conditions are met. Events activate component groups that change entity behavior—transforming villagers into zombie villagers, switching mobs to aggressive mode, or triggering growth stages. Combine with filters to create conditional state machines that respond to gameplay.",
          "body": {
            "event": "",
            "filters": {
              "AND": null,
              "NOT": null,
              "OR": null,
              "all": null,
              "all_of": null,
              "any": null,
              "any_of": null,
              "none_of": null
            },
            "target": "self"
          }
        }
      ]
    },
    "outer_boundary_time_increase": {
      "title": "Outer Boundary Time Increase",
      "description": "Time, in seconds, added to the attack path recalculation interval when the target is beyond \"path_outer_boundary\".",
      "type": "number",
      "default": 0.5
    },
    "path_fail_time_increase": {
      "title": "Path Fail Time Increase",
      "description": "Time, in seconds, added to the attack path recalculation interval when the mob cannot move along the current path.",
      "type": "number",
      "default": 0.75
    },
    "path_inner_boundary": {
      "title": "Path Inner Boundary",
      "description": "Distance at which to increase attack path recalculation by \"inner_boundary_time_increase\".",
      "type": "number",
      "default": 16
    },
    "path_outer_boundary": {
      "title": "Path Outer Boundary",
      "description": "Distance at which to increase attack path recalculation by \"outer_boundary_time_increase\".",
      "type": "number",
      "default": 32
    },
    "priority": {
      "title": "Priority",
      "description": "As priority approaches 0, the priority is increased. The higher the priority, the sooner this behavior will be executed as a goal.",
      "type": "integer",
      "default": 0
    },
    "random_stop_interval": {
      "title": "Random Stop Interval",
      "description": "Defines a 1-in-N chance for the mob to stop its current attack, where N equals \"random_stop_interval\".",
      "type": "integer",
      "default": 0
    },
    "reach_multiplier": {
      "title": "Reach Multiplier",
      "description": "Used with the base size of the entity to determine minimum target-distance before trying to deal attack damage.",
      "type": "number",
      "default": 1.5
    },
    "require_complete_path": {
      "title": "Require Complete Path",
      "description": "Specifies whether a full navigation path from the mob to the target is required.",
      "type": "boolean",
      "default": false
    },
    "sound_event": {
