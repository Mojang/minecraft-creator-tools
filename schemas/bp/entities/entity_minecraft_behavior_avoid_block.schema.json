    "control_flags": {
      "title": "Control Flags",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "jump",
          "look",
          "move"
        ]
      }
    },
    "priority": {
      "title": "Priority",
      "description": "As priority approaches 0, the priority is increased. The higher the priority, the sooner this behavior will be executed as a goal.\n\nSample values:\n• hoglin: 1",
      "type": "integer",
      "default": 0
    },
    "search_height": {
      "title": "Search Height",
      "description": "Maximum distance to look for a block in y.\n\nSample values:\n• hoglin: 4",
      "type": "integer",
      "default": 0
    },
    "search_range": {
      "title": "Search Range",
      "description": "Maximum distance to look for a block in xz.\n\nSample values:\n• hoglin: 8",
      "type": "integer",
      "default": 0
    },
    "sound_interval": {
      "title": "Sound Interval",
      "description": "The range of time in seconds to randomly wait before playing the sound again.\n\nProperties:\n• max (float) = 0\n• min (float) = 0\n\nSample values:\n• hoglin: {\"min\":2,\"max\":5}",
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        {
          "$ref": "../../common/floatrange.schema.json"
        }
      ]
    },
    "sprint_speed_modifier": {
      "title": "Sprint Speed Modifier",
      "description": "Modifier for sprint speed. 1.0 means keep the regular speed, while higher numbers make the sprint speed faster.\n\nSample values:\n• hoglin: 1",
      "type": "number",
      "default": 1
    },
    "target_blocks": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      ],
      "title": "Target Blocks",
      "description": "List of block types this mob avoids.\n\nSample values:\n• hoglin: [\"minecraft:warped_fungus\",\"minecraft:portal\",\"...",
      "defaultSnippets": [
        {
          "label": "Target Blocks (default)",
          "description": "Use default value: ",
          "body": []
        }
      ]
    },
    "target_selection_method": {
      "title": "Target Selection Method",
      "description": "Block search method.\n\nSample values:\n• hoglin: nearest",
      "type": "string",
      "default": "nearest"
    },
    "tick_interval": {
      "title": "Tick Interval",
      "description": "Should start tick interval.\n\nSample values:\n• hoglin: 5",
      "type": "integer",
      "default": 1
    },
    "walk_speed_modifier": {
      "title": "Walk Speed Modifier",
      "description": "Modifier for walking speed. 1.0 means keep the regular speed, while higher numbers make the walking speed faster.\n\nSample values:\n• hoglin: 1",
      "type": "number",
      "default": 1
    }
  }
