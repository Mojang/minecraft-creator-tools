    "entity_types": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        {
          "description": "\n\nProperties:\n• check_if_outnumbered (boolean) = false\n• cooldown (int) = 0\n• filters ({ domain, operator, subject, ... }) = {\"AND\":null,\"NOT\":nu\n• max_dist (float) = 16\n• max_flee (float) = 10\n• max_height (float) = -1\n• must_see (boolean)\n• must_see_forget_duration (int) = 3\n• ... and 4 more properties",
          "type": "object",
          "properties": {
            "check_if_outnumbered": {
              "title": "Check If Outnumbered",
              "description": "If true, the mob will check if its outnumbered",
              "type": "boolean",
              "default": false
            },
            "cooldown": {
              "title": "Cooldown",
              "description": "The amount of time in seconds that the mob has to wait before selecting a target of the same type again",
              "type": "integer",
              "default": 0
            },
            "filters": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "domain": {
                      "title": "Domain",
                      "description": "The domain the test should be performed in.",
                      "type": "object"
                    },
                    "operator": {
                      "title": "Operator",
                      "description": "The comparison to apply with 'value'.",
                      "type": "object"
                    },
                    "subject": {
                      "title": "Subject",
                      "description": "The subject of this filter test.",
                      "type": "object"
                    },
                    "test": {
                      "title": "Test",
                      "description": "The name of the test to apply.",
                      "type": "string"
                    },
                    "value": {
                      "title": "Value",
                      "description": "The value being compared with the test.",
                      "type": "object"
                    }
                  }
                },
                {
                  "type": "object"
                }
              ],
              "description": "Conditions that make this entry in the list valid\n\nProperties:\n• domain (object)\n• operator (object)\n• subject (object)\n• test (string)\n• value (object)"
            },
            "max_dist": {
              "title": "Max Dist",
              "description": "Maximum distance this mob can be away to be a valid choice",
              "type": "number",
              "default": 16
            },
            "max_flee": {
              "title": "Max Flee",
              "description": "Maximum distance this mob can be from the target to stop fleeing",
              "type": "number",
              "default": 10
            },
            "max_height": {
              "title": "Max Height",
              "description": "Maximum height this mob can be away to be a valid choice",
              "type": "number",
              "default": -1
            },
            "must_see": {
              "title": "Must See",
              "description": "If true, the mob has to be visible to be a valid choice",
              "type": "boolean"
            },
            "must_see_forget_duration": {
              "title": "Must See Forget Duration",
              "description": "Determines the amount of time in seconds that this mob will look for a target before forgetting about it and looking for a new one when the target isn't visible any more",
              "type": "integer",
              "default": 3
            },
            "priority": {
              "title": "Priority",
              "description": "Priority for this mob type",
              "type": "integer",
              "default": 0
            },
            "reevaluate_description": {
              "title": "Reevaluate Description",
              "description": "If true, the mob will stop being targeted if it stops meeting any conditions.",
              "type": "boolean",
              "default": false
            },
            "sprint_speed_multiplier": {
              "title": "Sprint Speed Multiplier",
              "description": "Multiplier for the sprinting speed. A value of 1.0 means the speed is unchanged",
              "type": "number",
              "default": 1
            },
            "walk_speed_multiplier": {
              "title": "Walk Speed Multiplier",
              "description": "Multiplier for the walking speed. A value of 1.0 means the speed is unchanged",
              "type": "number",
              "default": 1
            }
          },
          "defaultSnippets": [
            {
              "label": "Entity Types (object)",
              "description": "Use Entity Types as an object",
              "body": {
                "check_if_outnumbered": false,
                "cooldown": 0,
                "filters": {
                  "AND": null,
                  "NOT": null,
                  "OR": null,
                  "all": null,
                  "all_of": null,
                  "any": null,
                  "any_of": null,
                  "none_of": null
                },
                "max_dist": 16,
                "max_flee": 10,
                "max_height": -1,
                "must_see": true,
                "must_see_forget_duration": 3,
                "priority": 0,
                "reevaluate_description": false,
                "sprint_speed_multiplier": 1,
                "walk_speed_multiplier": 1
              }
            }
          ]
        }
      ],
      "title": "Entity Types",
      "description": "The list of conditions another entity must meet to be a valid target to avoid.\n\nSample values:\n• bogged: [{\"filters\":{\"test\":\"is_family\",\"subject\":\"othe...\n• cave_spider: [{\"filters\":{\"all_of\":[{\"test\":\"is_family\",\"sub...\n• dolphin: [{\"filters\":{\"any_of\":[{\"test\":\"is_family\",\"sub...",
