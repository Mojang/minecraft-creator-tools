{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Entity Hover Behavior",
  "description": "Allows the mob to hover in place.",
  "properties": {
    "control_flags": {
      "title": "Control Flags",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "jump",
          "look",
          "move"
        ]
      }
    },
    "priority": {
      "title": "Priority",
      "type": "integer",
      "default": 0
    }
  }
}