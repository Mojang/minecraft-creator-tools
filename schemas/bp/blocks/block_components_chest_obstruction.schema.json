{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Block Components Chest Obstruction",
  "description": "This defines how a block reacts to a chest being opened underneath it.",
  "properties": {
    "obstruction_rule": {
      "title": "Chest Obstruction Rule",
      "type": "string",
      "enum": [
        "always",
        "never",
        "shape"
      ],
      "default": "shape"
    }
  }
}