{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Client Particles Particle Motion Dynamic",
  "description": "Applies physics simulation to particle movement including gravity, acceleration, and air resistance. Linear acceleration adds constant force (gravity pulls down, wind pushes sideways), while drag slows particles over time. Rotation acceleration and drag control spinning. Creates natural-feeling motion for smoke rising, debris falling, or leaves drifting.",
  "properties": {
    "linear_acceleration": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
      "title": "Linear Acceleration",
      "description": "The linear acceleration of particles, as [x, y, z] Molang expressions or numbers."
    },
    "linear_drag_coefficient": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        }
      ],
      "title": "Linear Drag Coefficient",
      "description": "The drag coefficient applied to particle motion. Can be a number or Molang expression."
    },
    "rotation_acceleration": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        }
      ],
      "title": "Rotation Acceleration",
      "description": "The rotation acceleration. Can be a number or Molang expression."
    },
    "rotation_drag_coefficient": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        }
      ],
      "title": "Rotation Drag Coefficient",
      "description": "The rotation drag coefficient. Can be a number or Molang expression."
    }
  }
}