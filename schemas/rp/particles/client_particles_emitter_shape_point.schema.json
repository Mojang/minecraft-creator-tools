{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Client Particles Emitter Shape Point",
  "description": "Emits all particles from a single point in space, offset from the emitter origin. This is the simplest and most common emission shape—all particles spawn at the same location and spread outward based on their initial velocity. Used for torches, candles, sparks, magic projectile cores, and any effect with a focused emission source.",
  "properties": {
    "direction": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
      "title": "Direction",
      "description": "The direction of particle emission, as [x, y, z] Molang expressions."
    },
    "offset": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
      "title": "Offset",
      "description": "The offset from the emitter position, as [x, y, z] Molang expressions."
    }
  }
}