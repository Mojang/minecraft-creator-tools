        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
