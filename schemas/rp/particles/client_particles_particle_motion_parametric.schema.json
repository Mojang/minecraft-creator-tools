{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Client Particles Particle Motion Parametric",
  "description": "Controls particle position and rotation using Molang expressions evaluated each frame, overriding physics simulation. Position is relative to emitter origin, allowing mathematical motion patterns like orbits, waves, spirals, or any path describable through equations. Ideal for magical effects, precise choreographed motion, or synchronized particle formations.",
  "properties": {
    "relative_position": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
      "title": "Relative Position",
      "description": "Position offset relative to the particle emitter, as [x, y, z] Molang expressions."
    },
    "direction": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
      "title": "Direction",
      "description": "Direction of particle motion, as [x, y, z] Molang expressions."
    },
    "rotation": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        {
          "type": "string"
        },
        {
          "description": "\n\nProperties:\n• expression (string)\n• version (int)",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "expression": {
                "title": "Expression",
                "type": "string"
              },
              "version": {
                "title": "Version",
                "type": "integer"
              }
            }
          }
        },
        {
          "type": "number"
        }
      ],
      "title": "Rotation"
    }
  }
}