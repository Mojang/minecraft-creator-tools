{
  "name": "mctools-all-src",
  "version": "0.0.0-semantically-released",
  "productName": "Minecraft Creator Tools",
  "description": "Minecraft Creator Tools for building Bedrock Edition add-ons.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mojang/minecraft-creator-tools.git"
  },
  "scripts": {
    "build": "cd app && npm run jsnbuild",
    "lint": "cd app && npm run lint",
    "lint:fix": "cd app && npm run lint:fix",
    "webbuild": "cd app && npm run webbuild",
    "jsnbuild": "cd app && npm run jsnbuild",
    "jsncorebuild": "cd app && npm run jsncorebuild",
    "jsnfullbuild": "cd app && npm run jsnfullbuild",
    "vscbuild": "cd app && npm run vscbuild",
    "appbuild": "cd app && npm run appbuild",
    "corebuild": "cd app && npm run corebuild",
    "allbuild": "cd app && npm run allbuild",
    "web": "cd app && npm run web",
    "start": "cd app && npm run start",
    "serve": "cd app && npx mct serve",
    "test": "cd app && npm test",
    "test-cli": "cd app && npm run test-cli",
    "test-core": "cd app && npm run test-core",
    "test-mcp": "cd app && npm run test-mcp",
    "test-mcp-unit": "cd app && npm run test-mcp-unit",
    "test-web": "cd app && npm run test-web",
    "test-viewers": "cd app && npm run test-viewers",
    "test-server-ui": "cd app && npm run test-server-ui",
    "test-electron": "cd app && npm run test-electron",
    "test-electron-full": "cd app && npm run test-electron-full",
    "test-electron-dev": "cd app && npm run test-electron-dev",
    "preparedevenv": "cd app && npm run preparedevenv",
    "preparetest": "cd app && npm run preparetest",
    "preparemc": "cd app && npm run preparemc",
    "processdocs": "cd app && npm run processdocs",
    "all": "cd app && npm run all",
    "validate": "cd app && npx mct validate",
    "jsntest": "cd app && npm run jsntest"
  },
  "keywords": [
    "minecraft",
    "tools",
    "bedrock",
    "add-on",
    "creator"
  ], 
  "bugs": {
    "url": "https://aka.ms/mctbugs"
  },
  "license": "https://aka.ms/mctrlicense",
  "homepage": "https://aka.ms/mcthomepage",
  "private": false,
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      [
        "@semantic-release/npm",
        {
          "pkgRoot": "./app/toolbuild/jsn",
          "tarballDir": "dist",
          "provenance": true
        }
      ],
      [
        "@semantic-release/exec",
        {
          "execCwd": "app",
          "prepareCmd": "npm run updateversionsandbuild"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "dist/*.tgz",
              "label": "Minecraft Creator Tools command line"
            }
          ]
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "semantic-release": "^25.0.0"
  }
}
